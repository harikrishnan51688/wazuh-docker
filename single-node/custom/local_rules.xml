<!-- ============ RESOURCE MONITORING RULES ============ -->
<group name="resource_monitoring">
  <rule id="100100" level="3">
    <decoded_as>resource_metrics</decoded_as>
    <description>Resource Metrics - CPU: $(cpu_usage_%)%, Memory: $(memory_usage_%)%, Disk: $(disk_usage_%)%, Load: $(load_1min)</description>
    <group>resource_monitoring,system_health</group>
  </rule>
  <rule id="100200" level="3">
    <decoded_as>disk_metrics</decoded_as>
    <description>Disk Metrics - Used: $(disk_used_gb)GB, Free: $(disk_free_gb)GB</description>
    <group>resource_monitoring</group>
  </rule>
</group>

<!-- ============ T-POT HONEYPOT RULES ============ -->
<group name="honeypot,tpot">
  <rule id="101100" level="5">
    <decoded_as>json</decoded_as>
    <field name="eventid">^cowrie\.connected$</field>
    <description>Cowrie: SSH/Telnet connection from $(src_ip)</description>
    <group>cowrie,connection</group>
  </rule>
  <rule id="101101" level="7">
    <decoded_as>json</decoded_as>
    <field name="eventid">^cowrie\.login\.failed$</field>
    <description>Cowrie: SSH login failed - user=$(username) src=$(src_ip)</description>
    <group>cowrie,authentication_failed</group>
  </rule>
  <rule id="101102" level="12">
    <decoded_as>json</decoded_as>
    <field name="eventid">^cowrie\.login\.success$</field>
    <description>Cowrie: SSH login SUCCESS - user=$(username) src=$(src_ip)</description>
    <group>cowrie,authentication_success</group>
  </rule>
  <rule id="101103" level="10">
    <decoded_as>json</decoded_as>
    <field name="eventid">^cowrie\.command\.input$</field>
    <description>Cowrie: Command executed from $(src_ip)</description>
    <group>cowrie,command_execution</group>
  </rule>
  <rule id="101104" level="12">
    <decoded_as>json</decoded_as>
    <field name="eventid">^cowrie\.session\.file_download$</field>
    <description>Cowrie: Malware download from $(src_ip)</description>
    <group>cowrie,malware</group>
  </rule>
  <rule id="101105" level="14" frequency="5" timeframe="60">
    <if_matched_sid>101101</if_matched_sid>
    <same_field>src_ip</same_field>
    <description>Cowrie: SSH brute force from $(src_ip)</description>
    <group>cowrie,brute_force,correlation</group>
  </rule>
  <rule id="101200" level="5">
    <decoded_as>json</decoded_as>
    <field name="src_ip">\.+</field>
    <field name="dst_port">\.+</field>
    <field name="connection.type">^accept$</field>
    <description>Dionaea: Connection from $(src_ip) on port $(dst_port)</description>
    <group>dionaea,connection</group>
  </rule>
  <rule id="101201" level="10">
    <decoded_as>json</decoded_as>
    <field name="src_ip">\.+</field>
    <field name="connection.protocol">^smbd$</field>
    <field name="dst_port">^445$</field>
    <description>Dionaea: SMB connection from $(src_ip) - possible EternalBlue</description>
    <group>dionaea,smb,exploit</group>
  </rule>
  <rule id="101202" level="12">
    <decoded_as>json</decoded_as>
    <field name="src_ip">\.+</field>
    <field name="connection.type">^reject$</field>
    <description>Dionaea: Connection rejected from $(src_ip)</description>
    <group>dionaea,exploit</group>
  </rule>
  <rule id="101300" level="5">
    <decoded_as>json</decoded_as>
    <field name="src_ip">\.+</field>
    <field name="dest_port">\.+</field>
    <field name="trapped">^false$</field>
    <description>H0neytr4p: Probe from $(src_ip) on port $(dest_port)</description>
    <group>honeytrap,connection</group>
  </rule>
  <rule id="101301" level="12">
    <decoded_as>json</decoded_as>
    <field name="src_ip">\.+</field>
    <field name="trapped">^true$</field>
    <description>H0neytr4p: TRAPPED attacker from $(src_ip)</description>
    <group>honeytrap,attack</group>
  </rule>
  <rule id="101302" level="14" frequency="10" timeframe="30">
    <if_matched_sid>101300</if_matched_sid>
    <same_field>src_ip</same_field>
    <description>H0neytr4p: Port scan from $(src_ip)</description>
    <group>honeytrap,port_scan,correlation</group>
  </rule>
  <rule id="101400" level="5">
    <decoded_as>json</decoded_as>
    <field name="session_id">\.+</field>
    <field name="destination_port">\.+</field>
    <description>Heralding: Connection on port $(destination_port)</description>
    <group>heralding,connection</group>
  </rule>
  <rule id="101401" level="9">
    <decoded_as>json</decoded_as>
    <field name="session_id">\.+</field>
    <field name="auth_attempts">username</field>
    <description>Heralding: Credential attempt on port $(destination_port)</description>
    <group>heralding,authentication_failed</group>
  </rule>
  <rule id="101402" level="14" frequency="5" timeframe="60">
    <if_matched_sid>101401</if_matched_sid>
    <same_field>session_id</same_field>
    <description>Heralding: Credential spray detected</description>
    <group>heralding,credential_spray,correlation</group>
  </rule>
  <rule id="101500" level="10">
    <decoded_as>json</decoded_as>
    <field name="sensorid">^conpot$</field>
    <field name="src_ip">\.+</field>
    <description>Conpot: ICS/SCADA probe from $(src_ip)</description>
    <group>conpot,ics,reconnaissance</group>
  </rule>
  <rule id="101501" level="12">
    <decoded_as>json</decoded_as>
    <field name="sensorid">^conpot$</field>
    <field name="data_type">^modbus$</field>
    <description>Conpot: Modbus protocol access from $(src_ip)</description>
    <group>conpot,ics,modbus</group>
  </rule>
  <rule id="101700" level="5">
    <decoded_as>json</decoded_as>
    <field name="src_ip">\.+</field>
    <field name="plugin">\.+</field>
    <description>Wordpot: WordPress probe from $(src_ip)</description>
    <group>wordpot,web,reconnaissance</group>
  </rule>
  <rule id="101701" level="10">
    <decoded_as>json</decoded_as>
    <field name="src_ip">\.+</field>
    <field name="plugin">^badlogin$</field>
    <field name="username">\.+</field>
    <description>Wordpot: WordPress login attempt - user=$(username) from $(src_ip)</description>
    <group>wordpot,web,authentication_failed</group>
  </rule>
  <rule id="101702" level="10">
    <decoded_as>json</decoded_as>
    <field name="src_ip">\.+</field>
    <field name="plugin">^xmlrpc$</field>
    <description>Wordpot: WordPress XMLRPC exploit from $(src_ip)</description>
    <group>wordpot,web,exploit</group>
  </rule>
  <rule id="101703" level="14" frequency="5" timeframe="60">
    <if_matched_sid>101701</if_matched_sid>
    <same_field>src_ip</same_field>
    <description>Wordpot: WordPress brute force from $(src_ip)</description>
    <group>wordpot,web,brute_force,correlation</group>
  </rule>
  <rule id="101850" level="5">
    <decoded_as>json</decoded_as>
    <field name="src_ip">\.+</field>
    <field name="dest_port">^9100$</field>
    <field name="info">^Connection opened$</field>
    <description>Miniprint: Printer connection from $(src_ip)</description>
    <group>miniprint,connection</group>
  </rule>
  <rule id="101851" level="10">
    <decoded_as>json</decoded_as>
    <field name="src_ip">\.+</field>
    <field name="info">^Possible port scan$</field>
    <description>Miniprint: Port scan detected from $(src_ip)</description>
    <group>miniprint,port_scan</group>
  </rule>
  <rule id="101800" level="7">
    <decoded_as>redishoneypot</decoded_as>
    <description>Redis Honeypot: Connection from $(src_ip)</description>
    <group>redis,connection</group>
  </rule>
  <rule id="101900" level="15" frequency="3" timeframe="300">
    <if_matched_group>connection</if_matched_group>
    <same_field>src_ip</same_field>
    <description>T-POT: Multi-honeypot attack campaign from $(src_ip)</description>
    <group>tpot,correlation,critical</group>
  </rule>
</group>

<!-- ============ QUARANTINE ACTIVE RESPONSE RULES ============ -->
<group name="quarantine,">
  <rule id="100093" level="0">
    <match>quarantine-ar</match>
    <description>Quarantine active-response log.</description>
  </rule>
  <rule id="100094" level="10">
    <if_sid>100093</if_sid>
    <match>Successfully quarantined</match>
    <description>Server quarantined due to malicious activity.</description>
  </rule>
</group>
